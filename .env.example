# ============================================
# SENTINEL - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sentinel?retryWrites=true&w=majority

# --- WDK Configuration ---
WDK_SEED_PHRASE=your twelve word mnemonic seed phrase goes here
WDK_BLOCKCHAIN=ethereum
WDK_NETWORK=sepolia

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- LLM (Groq for fast credit reasoning) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Loan Defaults ---
DEFAULT_LOAN_DURATION_DAYS=30
MONITOR_POLL_INTERVAL_MS=60000
IDLE_CAPITAL_THRESHOLD_USDT=1000
