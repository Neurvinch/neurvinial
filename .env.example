# ============================================
# Neurvinial - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/neurvinial?retryWrites=true&w=majority

# --- WDK Configuration (REQUIRED) ---
# Generate a new seed phrase using WDK:
#   node -e "const WDK = require('@tetherto/wdk').default || require('@tetherto/wdk'); console.log(WDK.getRandomSeedPhrase(12));"
# Or use an existing BIP-39 12/24 word mnemonic
# IMPORTANT: Keep this secret! Anyone with this phrase controls your wallet.
WDK_SEED_PHRASE=your twelve word mnemonic seed phrase goes here
WDK_BLOCKCHAIN=ethereum
WDK_NETWORK=sepolia
# Optional: Provide your own RPC URL (Infura, Alchemy, etc.) for faster/more reliable access
WDK_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY

# --- ERC-4337 Account Abstraction (Optional - for gasless transactions) ---
# Real bundler and paymaster URLs
BUNDLER_URL=https://api.pimlico.io/v2/1/rpc?apikey=pim_k1X6vKzRMbstGthd8DFDGY
PAYMASTER_URL=https://api.candide.dev/api/v3/11155111/7fe640279475aa061bcec287385fe623
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
FACTORY_ADDRESS=
FALLBACK_HANDLER=

# --- Telegram Bot ---
# OPTION 1: Use OpenClaw Gateway (RECOMMENDED) for production
# Set OPENCLAW_GATEWAY_URL and let OpenClaw handle Telegram, WhatsApp, Slack, Discord, etc.
# See OPENCLAW_GATEWAY_SETUP.md for details
OPENCLAW_GATEWAY_URL=

# OPTION 2: Standalone bot (fallback/development)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- WhatsApp (Twilio) - Standalone only ---
# Not needed if using OpenClaw Gateway (which uses Baileys for WhatsApp)
# Get credentials at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+15551234567

# --- LLM (Groq for fast credit reasoning) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- API Security ---
# Comma-separated list of valid API keys for authentication
# Generate new keys with: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
API_KEYS=neurvinial_demo_key_2026,your_production_api_key_here

# --- Loan Defaults ---
DEFAULT_LOAN_DURATION_DAYS=30
MONITOR_POLL_INTERVAL_MS=60000
IDLE_CAPITAL_THRESHOLD_USDT=1000
